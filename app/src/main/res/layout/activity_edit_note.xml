<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout: Note Editor Screen (Modern Improved)
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/color_1"
    android:focusableInTouchMode="true"
    tools:openDrawer="start">

    <!-- ================= HEADER ================= -->
    <RelativeLayout
        android:id="@+id/header_container"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="?attr/color_1"
        android:elevation="0dp"
        android:paddingStart="6dp"
        android:paddingEnd="6dp">

        <!-- Back Button -->
        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_toolbar_btn"
            android:contentDescription="@string/cd_back"
            android:padding="11dp"
            android:src="@drawable/ic_back"
            app:tint="?attr/text_color" />

        <!-- Default Actions -->
        <LinearLayout
            android:id="@+id/layout_default_actions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btn_delete"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_toolbar_btn"
                android:contentDescription="@string/cd_delete"
                android:padding="11dp"
                android:visibility="gone"
                app:tint="?attr/text_color" />

            <ImageButton
                android:id="@+id/btn_share"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_toolbar_btn"
                android:contentDescription="@string/cd_share"
                android:padding="11dp"
                android:visibility="gone"
                app:tint="?attr/text_color" />

            <ImageButton
                android:id="@+id/btn_menu"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_toolbar_btn"
                android:contentDescription="@string/cd_menu"
                android:padding="11dp"
                android:src="@drawable/ic_menu"
                app:tint="?attr/text_color" />
        </LinearLayout>

        <!-- Input Actions -->
        <LinearLayout
            android:id="@+id/layout_input_actions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone">

            <ImageButton
                android:id="@+id/btn_undo"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_toolbar_btn"
                android:contentDescription="@string/cd_undo"
                android:padding="10dp"
                android:src="@drawable/ic_undo"
                app:tint="?attr/text_color" />

            <ImageButton
                android:id="@+id/btn_redo"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_toolbar_btn"
                android:contentDescription="@string/cd_redo"
                android:padding="10dp"
                android:src="@drawable/ic_redo"
                app:tint="?attr/text_color" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save_manual"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="4dp"
                android:contentDescription="@string/cd_save"
                android:minWidth="0dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="@string/cd_save"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:textStyle="bold"
                app:cornerRadius="14dp"
                app:icon="@drawable/ic_save"
                app:iconGravity="textStart"
                app:iconPadding="6dp"
                app:iconSize="16dp" />
        </LinearLayout>

    </RelativeLayout>

    <!-- ================= MAIN CONTENT ================= -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/keyboard_toolbar"
        android:layout_below="@id/header_container"
        android:clipToPadding="false"
        android:paddingStart="22dp"
        android:paddingTop="8dp"
        android:paddingEnd="22dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- TITLE -->
            <EditText
                android:id="@+id/et_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:alpha="0.92"
                android:autofillHints=""
                android:background="@null"
                android:fontFamily="@font/linottebold"
                android:hint="@string/title_hint"
                android:inputType="textCapSentences|textMultiLine"
                android:lineSpacingExtra="2dp"
                android:textColor="?attr/text_color"
                android:textColorHint="?attr/text_color"
                android:textSize="28sp"
                android:textStyle="bold" />

            <!-- Metadata -->
            <TextView
                android:id="@+id/tv_metadata"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="18dp"
                android:alpha="0.55"
                android:fontFamily="@font/linottesemibold"
                android:text="@string/metadata_placeholder"
                android:textColor="?attr/text_color"
                android:textSize="12sp" />

            <!-- Soft Divider -->
            <View
                android:layout_width="36dp"
                android:layout_height="3dp"
                android:layout_marginBottom="18dp"
                android:alpha="0.18"
                android:background="?attr/text_color" />

            <!-- CONTENT -->
            <EditText
                android:id="@+id/et_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:alpha="0.88"
                android:autofillHints=""
                android:background="@null"
                android:fontFamily="@font/linottesemibold"
                android:gravity="top|start"
                android:hint="@string/content_hint"
                android:inputType="textMultiLine|textCapSentences"
                android:lineSpacingExtra="10dp"
                android:minHeight="400dp"
                android:textColor="?attr/text_color"
                android:textColorHint="?attr/text_color"
                android:textCursorDrawable="@null"
                android:textSize="17sp" />

        </LinearLayout>
    </ScrollView>

    <!-- ================= SHARE PREVIEW ================= -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@id/keyboard_toolbar"
        android:layout_below="@id/header_container"
        android:background="?attr/color_1"
        android:orientation="vertical"
        android:padding="28dp"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="?attr/text_color"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:paddingBottom="10dp"
            android:textColor="?attr/text_color"
            android:textSize="12sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:lineSpacingExtra="8dp"
            android:textColor="?attr/text_color"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- ================= FLOATING KEYBOARD TOOLBAR ================= -->
    <HorizontalScrollView
        android:id="@+id/keyboard_toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="10dp"
        android:background="@drawable/bg_keyboard_toolbar"
        android:clipToOutline="true"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:padding="6dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/action_text_color"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_toolbar_btn"
                android:contentDescription="@string/cd_text_color"
                android:padding="10dp"
                android:src="@drawable/ic_text_color"
                app:tint="?attr/text_color" />

            <ImageButton
                android:id="@+id/action_highlight"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_toolbar_btn"
                android:contentDescription="@string/cd_highlight"
                android:padding="10dp"
                android:src="@drawable/ic_text_highlight"
                app:tint="?attr/text_color" />

            <View
                android:layout_width="1dp"
                android:layout_height="22dp"
                android:layout_marginHorizontal="8dp"
                android:alpha="0.12"
                android:background="?attr/text_color" />

            <ImageButton
                android:id="@+id/action_bold"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_toolbar_btn"
                android:contentDescription="@string/cd_bold"
                android:padding="10dp"
                android:src="@drawable/ic_text_bold"
                app:tint="?attr/text_color" />

            <ImageButton
                android:id="@+id/action_italic"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_toolbar_btn"
                android:contentDescription="@string/cd_italic"
                android:padding="10dp"
                android:src="@drawable/ic_text_italic"
                app:tint="?attr/text_color" />

            <ImageButton
                android:id="@+id/action_underline"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_toolbar_btn"
                android:contentDescription="@string/cd_underline"
                android:padding="10dp"
                android:src="@drawable/ic_text_underline"
                app:tint="?attr/text_color" />

            <ImageButton
                android:id="@+id/action_strike"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_toolbar_btn"
                android:contentDescription="@string/cd_strikethrough"
                android:padding="10dp"
                android:src="@drawable/ic_text_strikethrough"
                app:tint="?attr/text_color" />

            <View
                android:layout_width="1dp"
                android:layout_height="22dp"
                android:layout_marginHorizontal="8dp"
                android:alpha="0.12"
                android:background="?attr/text_color" />

            <ImageButton
                android:id="@+id/action_bullet_list"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_toolbar_btn"
                android:contentDescription="@string/cd_bullet_list"
                android:padding="10dp"
                android:src="@drawable/ic_text_list_bulleted"
                app:tint="?attr/text_color" />

            <ImageButton
                android:id="@+id/action_align_left"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_toolbar_btn"
                android:contentDescription="@string/cd_align_left"
                android:padding="10dp"
                android:src="@drawable/ic_text_align_left"
                app:tint="?attr/text_color" />

            <ImageButton
                android:id="@+id/action_align_center"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_toolbar_btn"
                android:contentDescription="@string/cd_align_center"
                android:padding="10dp"
                android:src="@drawable/ic_text_align_center"
                app:tint="?attr/text_color" />

            <ImageButton
                android:id="@+id/action_align_right"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_toolbar_btn"
                android:contentDescription="@string/cd_align_right"
                android:padding="10dp"
                android:src="@drawable/ic_text_align_right"
                app:tint="?attr/text_color" />

            <View
                android:layout_width="1dp"
                android:layout_height="22dp"
                android:layout_marginHorizontal="8dp"
                android:alpha="0.12"
                android:background="?attr/text_color" />

            <ImageButton
                android:id="@+id/action_size_up"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_toolbar_btn"
                android:contentDescription="@string/cd_size_up"
                android:padding="10dp"
                android:src="@drawable/ic_text_increase"
                app:tint="?attr/text_color" />

            <ImageButton
                android:id="@+id/action_size_down"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_toolbar_btn"
                android:contentDescription="@string/cd_size_down"
                android:padding="10dp"
                android:src="@drawable/ic_text_decrease"
                app:tint="?attr/text_color" />

        </LinearLayout>
    </HorizontalScrollView>

</RelativeLayout>