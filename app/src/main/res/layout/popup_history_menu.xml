<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:minWidth="128dp"
    android:background="@drawable/bg_menu_history"
    android:elevation="8dp"
    android:orientation="vertical"
    android:paddingVertical="6dp">

    <!-- Rename -->
    <LinearLayout
        android:id="@+id/menuRename"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_marginHorizontal="6dp"
        android:layout_marginVertical="2dp"
        android:background="@drawable/bg_popup_item"
        android:clickable="true"
        android:focusable="true"
        android:gravity="start|center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="14dp">

        <ImageView
            android:layout_width="17dp"
            android:layout_height="17dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_edit"
            app:tint="?attr/text_color" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:fontFamily="@font/linottesemibold"
            android:text="@string/action_rename"
            android:textColor="?attr/text_color"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginHorizontal="12dp"
        android:layout_marginVertical="4dp"
        android:alpha="0.10"
        android:background="?attr/text_color" />

    <!-- Delete -->
    <LinearLayout
        android:id="@+id/menuDelete"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_marginHorizontal="6dp"
        android:layout_marginVertical="2dp"
        android:background="@drawable/bg_popup_item"
        android:clickable="true"
        android:focusable="true"
        android:gravity="start|center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="14dp">

        <ImageView
            android:layout_width="17dp"
            android:layout_height="17dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_delete"
            app:tint="?attr/color_error" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:fontFamily="@font/linottesemibold"
            android:text="@string/action_delete"
            android:textColor="?attr/color_error"
            android:textSize="13sp" />
    </LinearLayout>

</LinearLayout>