<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout: Note Popup Menu (Modern Compact)
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:minWidth="128dp"
    android:background="@drawable/bg_menu_history"
    android:orientation="vertical"
    android:padding="8dp"
    tools:ignore="ExtraText">

    <!-- Reminder -->
    <LinearLayout
        android:id="@+id/action_reminder"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:background="@drawable/bg_toolbar_btn"
        android:clickable="true"
        android:focusable="true"
        android:gravity="start|center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="16dp">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:contentDescription="@string/cd_action_reminder"
            android:src="@drawable/ic_reminder"
            app:tint="?attr/text_color" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:fontFamily="@font/linottesemibold"
            android:text="@string/action_reminder_text"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/text_color"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Share -->
    <LinearLayout
        android:id="@+id/action_share"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:layout_marginTop="2dp"
        android:background="@drawable/bg_toolbar_btn"
        android:clickable="true"
        android:focusable="true"
        android:gravity="start|center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="16dp">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:contentDescription="@string/cd_action_share"
            android:src="@drawable/ic_share"
            app:tint="?attr/text_color" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:fontFamily="@font/linottesemibold"
            android:text="@string/action_share_note"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/text_color"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginHorizontal="8dp"
        android:layout_marginVertical="6dp"
        android:alpha="0.12"
        android:background="?attr/text_color" />

    <!-- Delete -->
    <LinearLayout
        android:id="@+id/action_delete"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:background="@drawable/bg_toolbar_btn"
        android:clickable="true"
        android:focusable="true"
        android:gravity="start|center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="16dp">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:contentDescription="@string/cd_action_delete"
            android:src="@drawable/ic_delete"
            app:tint="?attr/color_error" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:fontFamily="@font/linottesemibold"
            android:text="@string/action_delete_note"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/color_error"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>